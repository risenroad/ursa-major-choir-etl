RAW_SPREADSHEET_ID=
TARGET_SPREADSHEET_ID=

# Recommended: path to local service account JSON key file (ignored by git)
GOOGLE_SERVICE_ACCOUNT_FILE=

# Fallback (less convenient): JSON contents as a single-line string
# GOOGLE_SERVICE_ACCOUNT_JSON=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Weekly missed-streak alerts (after ETL)
ALERTS_ENABLED=1
ALERTS_STREAK_THRESHOLD=3
ALERTS_LOOKBACK_WEEKS=3
# ALERTS_DRY_RUN=1 — только вывести текст в консоль, в Telegram не отправлять

